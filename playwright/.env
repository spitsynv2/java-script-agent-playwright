# ESG injects PLAYWRIGHT_WS_ENDPOINT and ZEBRUNNER_HUB_URL into the container.
# Each Playwright worker connects to the WS endpoint.
# ESG creates a separate browser container per connection.
# Auth is extracted from ZEBRUNNER_HUB_URL and sent as Authorization header.
#
# When PLAYWRIGHT_WS_ENDPOINT is unset, tests launch browsers locally.

# PW_WORKERS=4

# REPORTING_ENABLED=true
# REPORTING_PROJECT_KEY=DEF
# REPORTING_SERVER_HOSTNAME=https://yourCompany.zebrunner.com
# REPORTING_SERVER_ACCESS_TOKEN=yourAccessToken
# REPORTING_LAUNCH_DISPLAY_NAME=Playwright ESG Grid
