# Injected by ESG when image name contains "playwright":
# PLAYWRIGHT_WS_ENDPOINT=wss://esg-host/playwright/hub/<parent-task-uuid>
#
# Each Playwright worker connects to this URL.
# ESG creates a separate browser container per connection.
# When unset, tests launch browsers locally.

# PW_WORKERS=4

# REPORTING_ENABLED=true
# REPORTING_PROJECT_KEY=DEF
# REPORTING_SERVER_HOSTNAME=https://yourCompany.zebrunner.com
# REPORTING_SERVER_ACCESS_TOKEN=yourAccessToken
# REPORTING_LAUNCH_DISPLAY_NAME=Playwright ESG Grid
