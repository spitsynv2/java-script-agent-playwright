# iOS Safari testing via Playwright WebKit
#
# Remote (ios-server or gateway):
# IOS_WS_ENDPOINT=ws://gateway:5000/device/iPhone_15
#
# Device preset (from Playwright's device list):
# IOS_DEVICE_NAME=iPhone 15
#
# Local: leave IOS_WS_ENDPOINT unset, run `npx playwright install webkit`

# REPORTING_ENABLED=true
# REPORTING_SERVER_HOSTNAME=https://yourCompany.zebrunner.com
# REPORTING_SERVER_ACCESS_TOKEN=yourAccessToken
