# ── Mode A (recommended): connect via android-server / gateway ──
# One URL — gateway resolves device by name or serial in the path.
# ANDROID_WS_ENDPOINT=ws://gateway-host:5000/device/Pixel_3_XL
#
# Or direct to a single android-server sidecar:
# ANDROID_WS_ENDPOINT=ws://android-server-pixel3:4000/<ws-path>

# ── Mode B: direct adb (testing / same-host only) ──
# ADB_SERVER_HOST=127.0.0.1
# ADB_SERVER_PORT=5037
# ANDROID_SERIAL=96JY1BL9Z
# ANDROID_OMIT_DRIVER_INSTALL=true

# Zebrunner reporting (optional)
# REPORTING_ENABLED=true
# REPORTING_PROJECT_KEY=DEF
# REPORTING_SERVER_HOSTNAME=https://yourCompany.zebrunner.com
# REPORTING_SERVER_ACCESS_TOKEN=yourAccessToken
# REPORTING_LAUNCH_DISPLAY_NAME=Playwright Android real device
